{
  "name": "zip-book-viewer",
  "version": "0.1.0",
  "private": true,
  "description": "Electron ZIP book viewer",
  "main": "dist/main/electron-main.js",
  "scripts": {
    "check": "tsc --noEmit",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:electron": "wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev": "npm run build:main && concurrently -k -n \"vite,main,electron\" -c \"cyan,magenta,green\" \"npm run dev:renderer\" \"npm run dev:main\" \"npm run dev:electron\"",
    "dist:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/yauzl": "^2.10.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12",
    "nodemon": "^3.1.14",
    "typescript": "^5.8.2",
    "vite": "^8.0.11",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.mongtang.zipbookviewer",
    "productName": "ZIP 이미지 뷰어",
    "extraResources": [
      "assets/data-file-icon.ico"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "index.html",
      "converter.html",
      "help.html",
      "styles.css",
      "assets/**/*",
      "package.json",
      "!PLAN.MD",
      "!RULES.MD"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
